# FindLy Docker env sample for Windows
HOST_USERS_PATH=C:/Users

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE_NAME=index_queue

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=findly

# Embedding Configuration
EMBEDDING_NAME=clip
EMBEDDING_FEATURE_LENGTH=512

# Data directories
INDEXED_FILES_DB=indexed_files.json
PC_DATA_DIR_NAME=pc_data

# Indexing directories (adjust to your system)
PC_INDEXING_DIR=~

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
EMBEDDING_API_HOST=0.0.0.0
EMBEDDING_API_PORT=5000
